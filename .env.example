# ===== SERVER =====
PORT=8080
HOST=0.0.0.0

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== PUSHER (Fallback WebSocket) =====
PUSHER_APP_ID=your_app_id
PUSHER_KEY=6c40eb129881d9bb18cf
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=mt1

# ===== VAPID (Web Push) =====
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@catlover.app

# ===== TELEGRAM BOT (Optional) =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://api.catlover.app/api/telegram/webhook

# ===== MEDIA STORAGE =====
MEDIA_UPLOAD_DIR=./uploads
MEDIA_MAX_SIZE=52428800  # 50MB in bytes

# ===== SECURITY =====
CORS_ORIGINS=https://catlover.app,https://www.catlover.app
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ===== ENVIRONMENT =====
ENV=development
LOG_LEVEL=info
